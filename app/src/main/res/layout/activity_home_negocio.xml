<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:fillViewport="true"
    tools:context=".HomeNegocioActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textMarca"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Inventario"
                android:textColor="@color/app_text_primary"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/textPuntoMarca"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_avatar_accent" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textSaludo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hola"
                    android:textColor="@color/app_text_primary"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/textNombreNegocio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mi negocio"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/textAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_avatar_accent"
                android:gravity="center"
                android:text="U"
                android:textColor="@color/white"
                android:textSize="17sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="7dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vendido hoy"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/textVendidoHoy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="$0.00"
                    android:textColor="@color/app_info"
                    android:textSize="22sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ventas hoy"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/textVentasHoy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0"
                    android:textColor="@color/app_text_primary"
                    android:textSize="22sp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Productos con stock bajo"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/textStockBajo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_accent"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="0"
                android:textColor="@color/app_warning"
                android:textSize="14sp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonNuevaVenta"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/app_accent"
            android:text="Nueva venta\nRegistrar venta rapida"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:cornerRadius="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Acciones rápidas"
            android:textColor="@color/app_text_primary"
            android:textSize="17sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHistorialVentas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/app_surface"
                android:text="Historial"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                app:cornerRadius="10dp"
                app:strokeColor="@color/app_border_strong"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonMovimientos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/app_surface"
                android:text="Inventario / Movimientos"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                app:cornerRadius="10dp"
                app:strokeColor="@color/app_border_strong"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonProductos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/app_surface"
                android:text="Productos"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                app:cornerRadius="10dp"
                app:strokeColor="@color/app_border_strong"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/app_surface"
                android:text="Categorías"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                app:cornerRadius="10dp"
                app:strokeColor="@color/app_border_strong"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonReportes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/app_surface"
                android:text="Reportes"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                app:cornerRadius="10dp"
                app:strokeColor="@color/app_border_strong"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Actividad reciente"
            android:textColor="@color/app_text_primary"
            android:textSize="17sp" />

        <LinearLayout
            android:id="@+id/contenedorVentasRecientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/layoutVentasVacias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aún no hay ventas"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPrimeraVenta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/app_accent"
                android:text="Registrar primera venta"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="10dp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/app_surface_elevated"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textColor="@color/app_text_secondary"
            app:cornerRadius="10dp"
            app:strokeColor="@color/app_border_strong"
            app:strokeWidth="1dp" />

    </LinearLayout>
</ScrollView>
